{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2021",
    "lib": ["ES2021"],
    "types": ["node"],
    "outDir": "dist",
    "declaration": false,
    "declarationMap": false,
    "incremental": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@sakin/shared": ["../../packages/shared/src/index.ts"],
      "@sakin/database": ["../../packages/database/src/index.ts"]
    }
  },
  "include": [
    "src",
    "../../packages/shared/src",
    "../../packages/database/src"
  ],
  "exclude": ["dist", "node_modules"]
}
