{
  "name": "@sakin/api-metadata",
  "version": "0.1.0",
  "private": true,
  "description": "Metadata service shell (S1-03 bootstrap)",
  "scripts": {
    "build": "node -e \"console.log('api-metadata first-pass metadata modules wired. Full nest build runs when toolchain is available.')\"",
    "dev": "node ../../scripts/start-service-shell.mjs --service api-metadata --port-env API_METADATA_PORT --default-port 3103",
    "start": "node ../../scripts/start-service-shell.mjs --service api-metadata --port-env API_METADATA_PORT --default-port 3103",
    "typecheck": "node -e \"console.log('api-metadata first-pass typecheck placeholder. TS strict check will be enforced in CI/toolchain stage.')\"",
    "lint": "node ../../scripts/check-cross-service-imports.mjs --app api-metadata",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-fastify": "^11.0.1",
    "@nestjs/swagger": "^11.0.3",
    "@sakin/api-core": "workspace:*",
    "@sakin/database": "workspace:*",
    "@sakin/shared": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3"
  }
}
