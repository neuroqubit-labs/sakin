# Mobile environment variables (local dev)
# Fiziksel cihazdan bağlanıyorsanız 'localhost' yerine Metro host IP'si kullanın;
# api.ts bunu runtime'da otomatik swap eder.

EXPO_PUBLIC_API_URL=http://localhost:3001/api/v1
EXPO_PUBLIC_ENV=development

# Push notification bağlandığında:
#   pnpm --filter=@sakin/mobile add expo-notifications
# Firebase/APNs credential'ları Expo projesine yüklenir; kod değişikliği gerekmez —
# use-push-registration hook'u otomatik devreye girer.
