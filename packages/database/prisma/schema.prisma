generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────
// Organizasyon
// ──────────────────────────────────────────

model Tenant {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  contactEmail String
  contactPhone String
  city         String
  address      String?
  isActive     Boolean  @default(true)
  suspendedAt     DateTime?
  suspendedReason String?
  suspendedBy     String?
  activityNotes   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users                 UserTenantRole[]
  sites                 Site[]
  blocks                Block[]
  units                 Unit[]
  residents             Resident[]
  occupancies           UnitOccupancy[]
  duesDefinitions       DuesDefinition[]
  dues                  Dues[]
  payments              Payment[]
  paymentAttempts       PaymentAttempt[]
  paymentProviderEvents PaymentProviderEvent[]
  ledgerEntries         LedgerEntry[]
  exportBatches         ExportBatch[]
  notifications         Notification[]
  paymentGateways       TenantPaymentGatewayConfig[]
  expenses              Expense[]
  announcements         Announcement[]
  plan                  TenantPlan?
  cashAccounts          CashAccount[]
  cashTransactions      CashTransaction[]
  siteStaff             SiteStaff[]
  vendors               Vendor[]
  tickets               Ticket[]
  ticketComments        TicketComment[]
  ticketAttachments     TicketAttachment[]
  legalCases            LegalCase[]
  legalCaseEvents       LegalCaseEvent[]
  documents             Document[]
  contracts             Contract[]
  communicationLogs     CommunicationLog[]
  facilities            Facility[]
  meetings              Meeting[]
  meetingDecisions      MeetingDecision[]
  notificationPreferences NotificationPreference[]
  deviceTokens            DeviceToken[]

  @@index([slug])
  @@map("tenants")
}

model User {
  id           String   @id @default(uuid())
  firebaseUid  String?  @unique
  email        String?  @unique
  phoneNumber  String?
  displayName  String?
  passwordHash String?
  isActive     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantRoles              UserTenantRole[]
  residentProfiles         Resident[]
  initiatedPaymentAttempts PaymentAttempt[]     @relation("PaymentAttemptInitiatedBy")
  paymentsPaid             Payment[]            @relation("PaymentPaidByUser")
  paymentsApproved         Payment[]            @relation("PaymentApprovedByUser")
  ledgerEntriesCreated     LedgerEntry[]        @relation("LedgerEntryCreatedBy")
  occupanciesCreated       UnitOccupancy[]      @relation("UnitOccupancyCreatedBy")
  exportsRequested         ExportBatch[]        @relation("ExportBatchRequestedBy")
  notificationsSent        Notification[]       @relation("NotificationSentByUser")
  notifications            Notification[]
  announcementsCreated     Announcement[]       @relation("AnnouncementCreatedBy")
  expensesCreated          Expense[]            @relation("ExpenseCreatedBy")
  cashTransactionsCreated  CashTransaction[]    @relation("CashTransactionCreatedBy")
  siteStaffProfiles        SiteStaff[]
  ticketsReported          Ticket[]             @relation("TicketReportedBy")
  ticketComments           TicketComment[]      @relation("TicketCommentAuthor")
  ticketAttachmentsUploaded TicketAttachment[]  @relation("TicketAttachmentUploadedBy")
  legalCaseEvents          LegalCaseEvent[]     @relation("LegalCaseEventCreatedBy")
  documentsUploaded        Document[]           @relation("DocumentUploadedBy")
  contractsCreated         Contract[]           @relation("ContractCreatedBy")
  communicationLogsSent    CommunicationLog[]   @relation("CommunicationLogSentBy")
  meetingsCreated          Meeting[]            @relation("MeetingCreatedBy")
  notificationPreferences  NotificationPreference[]
  deviceTokens             DeviceToken[]

  @@index([firebaseUid])
  @@index([phoneNumber])
  @@map("users")
}

model OtpCode {
  id          String    @id @default(uuid())
  phoneNumber String
  codeHash    String
  expiresAt   DateTime
  attempts    Int       @default(0)
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([phoneNumber, createdAt])
  @@index([expiresAt])
  @@map("otp_codes")
}

model UserTenantRole {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String?
  role      UserRole
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id])
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([role])
  @@map("user_tenant_roles")
}

model TenantPaymentGatewayConfig {
  id             String          @id @default(uuid())
  tenantId       String
  provider       PaymentProvider @default(IYZICO)
  mode           GatewayMode     @default(TEST)
  apiKey         String
  secretKey      String
  merchantName   String?
  merchantId     String?
  subMerchantKey String?
  isActive       Boolean         @default(true)
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, provider])
  @@index([tenantId, isActive])
  @@map("tenant_payment_gateway_configs")
}

// ──────────────────────────────────────────
// Fiziksel Yapi
// ──────────────────────────────────────────

model Site {
  id         String   @id @default(uuid())
  tenantId   String
  name       String
  address    String
  city       String
  district   String?
  totalUnits Int
  hasBlocks  Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  blocks            Block[]
  units             Unit[]
  duesDefinitions   DuesDefinition[]
  expenses          Expense[]
  announcements     Announcement[]
  cashAccounts      CashAccount[]
  siteStaff         SiteStaff[]
  ledgerEntries     LedgerEntry[]
  tickets           Ticket[]
  legalCases        LegalCase[]
  contracts         Contract[]
  communicationLogs CommunicationLog[]
  facilities        Facility[]
  meetings          Meeting[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("sites")
}

model Block {
  id         String   @id @default(uuid())
  tenantId   String
  siteId     String
  name       String
  totalUnits Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  site   Site   @relation(fields: [siteId], references: [id])
  units  Unit[]

  @@unique([siteId, name])
  @@index([tenantId])
  @@index([siteId])
  @@index([tenantId, siteId])
  @@map("blocks")
}

model Unit {
  id          String   @id @default(uuid())
  tenantId    String
  siteId      String
  blockId     String?
  number      String
  floor       Int?
  type        UnitType @default(APARTMENT)
  area        Float?
  description String?
  isStaffQuarters  Boolean  @default(false)
  isExemptFromDues Boolean  @default(false)
  customDuesAmount Decimal? @db.Decimal(12, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  site            Site             @relation(fields: [siteId], references: [id])
  block           Block?           @relation(fields: [blockId], references: [id])
  occupancies     UnitOccupancy[]
  dues            Dues[]
  payments        Payment[]
  paymentAttempts PaymentAttempt[]
  ledgerEntries   LedgerEntry[]
  notifications   Notification[]
  tickets         Ticket[]
  legalCases      LegalCase[]

  @@unique([siteId, blockId, number])
  @@index([tenantId])
  @@index([siteId])
  @@index([blockId])
  @@map("units")
}

// ──────────────────────────────────────────
// Kisiler
// ──────────────────────────────────────────

model Resident {
  id          String       @id @default(uuid())
  tenantId    String
  userId      String?
  firstName   String
  lastName    String
  email       String?
  phoneNumber String
  tckn        String?
  type        ResidentType
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  user              User?              @relation(fields: [userId], references: [id])
  occupancies       UnitOccupancy[]
  payments          Payment[]
  notifications     Notification[]
  legalCases        LegalCase[]
  communicationLogs CommunicationLog[]

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([phoneNumber])
  @@map("residents")
}

model UnitOccupancy {
  id                   String        @id @default(uuid())
  tenantId             String
  unitId               String
  residentId           String
  role                 OccupancyRole
  isPrimaryResponsible Boolean       @default(false)
  startDate            DateTime
  endDate              DateTime?
  isActive             Boolean       @default(true)
  createdByUserId      String?
  note                 String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  unit          Unit     @relation(fields: [unitId], references: [id])
  resident      Resident @relation(fields: [residentId], references: [id])
  createdByUser User?    @relation("UnitOccupancyCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([unitId, isActive])
  @@index([residentId, isActive])
  @@index([residentId, isActive, startDate])
  @@index([tenantId, unitId, isPrimaryResponsible, isActive])
  @@map("unit_occupancies")
}

// ──────────────────────────────────────────
// Finansal — Aidat & Borc
// ──────────────────────────────────────────

model DuesDefinition {
  id          String   @id @default(uuid())
  tenantId    String
  siteId      String?
  name        String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("TRY")
  type        DuesType @default(AIDAT)
  dueDay      Int
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  site   Site?  @relation(fields: [siteId], references: [id])
  dues   Dues[]

  @@index([tenantId])
  @@index([siteId])
  @@map("dues_definitions")
}

model Dues {
  id               String     @id @default(uuid())
  tenantId         String
  unitId           String
  duesDefinitionId String?
  amount           Decimal    @db.Decimal(12, 2)
  currency         String     @default("TRY")
  status           DuesStatus @default(PENDING)
  dueDate          DateTime
  periodMonth      Int
  periodYear       Int
  description      String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  unit            Unit             @relation(fields: [unitId], references: [id])
  duesDefinition  DuesDefinition?  @relation(fields: [duesDefinitionId], references: [id])
  payments        Payment[]
  paymentAttempts PaymentAttempt[]

  // Unique constraint enforced by raw SQL partial indexes in migration:
  // - dues_unit_def_period_uq (WHERE duesDefinitionId IS NOT NULL)
  // - dues_unit_adhoc_period_uq (WHERE duesDefinitionId IS NULL)

  @@index([tenantId])
  @@index([unitId])
  @@index([status])
  @@index([dueDate])
  @@map("dues")
}

// ──────────────────────────────────────────
// Finansal — Odeme
// ──────────────────────────────────────────

model Payment {
  id                String          @id @default(uuid())
  tenantId          String
  unitId            String
  duesId            String?
  paidByUserId      String?
  paidByResidentId  String?
  approvedByUserId  String?
  amount            Decimal         @db.Decimal(12, 2)
  currency          String          @default("TRY")
  method            PaymentMethod
  channel           PaymentChannel
  provider          PaymentProvider @default(MANUAL)
  status            PaymentStatus   @default(PENDING)
  purpose           PaymentPurpose  @default(DUES)
  providerPaymentId String?
  conversationId    String?
  providerToken     String?
  externalReference String?
  paidAt            DateTime?
  confirmedAt       DateTime?
  failedAt          DateTime?
  cancelledAt       DateTime?
  refundedAt        DateTime?
  note              String?
  receiptNumber     String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  tenant         Tenant                 @relation(fields: [tenantId], references: [id])
  unit           Unit                   @relation(fields: [unitId], references: [id])
  dues           Dues?                  @relation(fields: [duesId], references: [id])
  paidByUser     User?                  @relation("PaymentPaidByUser", fields: [paidByUserId], references: [id])
  paidByResident Resident?              @relation(fields: [paidByResidentId], references: [id])
  approvedByUser User?                  @relation("PaymentApprovedByUser", fields: [approvedByUserId], references: [id])
  attempts       PaymentAttempt[]
  providerEvents PaymentProviderEvent[]

  @@unique([tenantId, provider, providerPaymentId])
  @@index([tenantId])
  @@index([unitId])
  @@index([duesId])
  @@index([status])
  @@index([method])
  @@index([paidAt])
  @@index([conversationId])
  @@map("payments")
}

model PaymentAttempt {
  id                String               @id @default(uuid())
  tenantId          String
  paymentId         String?
  unitId            String
  duesId            String?
  initiatedByUserId String?
  amount            Decimal              @db.Decimal(12, 2)
  currency          String               @default("TRY")
  provider          PaymentProvider
  method            PaymentMethod
  channel           PaymentChannel
  status            PaymentAttemptStatus @default(INITIATED)
  conversationId    String
  providerReference String?
  providerToken     String?
  callbackUrl       String?
  metadata          Json?
  expiresAt         DateTime?
  processedAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  tenant          Tenant                 @relation(fields: [tenantId], references: [id])
  payment         Payment?               @relation(fields: [paymentId], references: [id])
  unit            Unit                   @relation(fields: [unitId], references: [id])
  dues            Dues?                  @relation(fields: [duesId], references: [id])
  initiatedByUser User?                  @relation("PaymentAttemptInitiatedBy", fields: [initiatedByUserId], references: [id])
  providerEvents  PaymentProviderEvent[]

  @@unique([tenantId, conversationId])
  @@index([tenantId])
  @@index([paymentId])
  @@index([unitId])
  @@index([status])
  @@index([tenantId, unitId, status])
  @@map("payment_attempts")
}

model PaymentProviderEvent {
  id               String              @id @default(uuid())
  tenantId         String
  paymentAttemptId String?
  paymentId        String?
  provider         PaymentProvider
  eventType        String
  eventId          String
  signature        String?
  processStatus    ProviderEventStatus @default(PENDING)
  payload          Json
  receivedAt       DateTime            @default(now())
  processedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  paymentAttempt PaymentAttempt? @relation(fields: [paymentAttemptId], references: [id])
  payment        Payment?        @relation(fields: [paymentId], references: [id])

  @@unique([tenantId, provider, eventId])
  @@index([tenantId])
  @@index([paymentAttemptId])
  @@index([paymentId])
  @@index([processStatus])
  @@map("payment_provider_events")
}

// ──────────────────────────────────────────
// Finansal — Muhasebe
// ──────────────────────────────────────────

model LedgerEntry {
  id              String              @id @default(uuid())
  tenantId        String
  unitId          String?
  siteId          String?
  amount          Decimal             @db.Decimal(12, 2)
  currency        String              @default("TRY")
  entryType       LedgerEntryType
  referenceType   LedgerReferenceType
  referenceId     String
  idempotencyKey  String?
  effectiveAt     DateTime
  createdByUserId String?
  note            String?
  metadata        Json?
  createdAt       DateTime            @default(now())

  tenant        Tenant @relation(fields: [tenantId], references: [id])
  unit          Unit?  @relation(fields: [unitId], references: [id])
  site          Site?  @relation(fields: [siteId], references: [id])
  createdByUser User?  @relation("LedgerEntryCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([tenantId, unitId, effectiveAt])
  @@index([tenantId, siteId, effectiveAt])
  @@index([tenantId, referenceType, referenceId])
  @@map("ledger_entries")
}

model Expense {
  id          String          @id @default(uuid())
  tenantId    String
  siteId      String
  vendorId    String?
  contractId  String?
  amount      Decimal         @db.Decimal(12, 2)
  category    ExpenseCategory
  payerScope  ExpensePayerScope @default(ALL)
  description String
  date        DateTime
  receiptUrl  String?
  createdById String
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  site      Site      @relation(fields: [siteId], references: [id])
  vendor    Vendor?   @relation(fields: [vendorId], references: [id])
  contract  Contract? @relation(fields: [contractId], references: [id])
  createdBy User      @relation("ExpenseCreatedBy", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([siteId])
  @@index([date])
  @@index([vendorId])
  @@map("expenses")
}

// ──────────────────────────────────────────
// Kasa & Banka
// ──────────────────────────────────────────

model CashAccount {
  id        String          @id @default(uuid())
  tenantId  String
  siteId    String
  name      String
  type      CashAccountType
  bankName  String?
  iban      String?
  currency  String          @default("TRY")
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  site         Site              @relation(fields: [siteId], references: [id])
  transactions CashTransaction[]

  @@unique([tenantId, siteId, name])
  @@index([tenantId, siteId])
  @@map("cash_accounts")
}

model CashTransaction {
  id              String              @id @default(uuid())
  tenantId        String
  cashAccountId   String
  amount          Decimal             @db.Decimal(12, 2)
  type            CashTransactionType
  referenceType   CashReferenceType?
  referenceId     String?
  description     String
  transactionDate DateTime
  createdById     String
  createdAt       DateTime            @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  cashAccount CashAccount @relation(fields: [cashAccountId], references: [id])
  createdBy   User        @relation("CashTransactionCreatedBy", fields: [createdById], references: [id])

  @@index([tenantId, cashAccountId, transactionDate])
  @@map("cash_transactions")
}

// ──────────────────────────────────────────
// Tedarikci
// ──────────────────────────────────────────

model Vendor {
  id          String           @id @default(uuid())
  tenantId    String
  name        String
  taxNumber   String?
  phone       String?
  email       String?
  address     String?
  category    ExpenseCategory?
  iban        String?
  contactName String?
  isActive    Boolean          @default(true)
  note        String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  expenses  Expense[]
  contracts Contract[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("vendors")
}

// ──────────────────────────────────────────
// Bina Personeli
// ──────────────────────────────────────────

model SiteStaff {
  id          String        @id @default(uuid())
  tenantId    String
  siteId      String
  userId      String?
  firstName   String
  lastName    String
  phoneNumber String
  role        SiteStaffRole
  isActive    Boolean       @default(true)
  startDate   DateTime?
  endDate     DateTime?
  note        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  site    Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id])
  tickets Ticket[]

  @@unique([userId, siteId])
  @@index([tenantId, siteId])
  @@map("site_staff")
}

// ──────────────────────────────────────────
// Talep / Ariza Yonetimi
// ──────────────────────────────────────────

model Ticket {
  id              String         @id @default(uuid())
  tenantId        String
  siteId          String
  unitId          String?
  reportedById    String?
  assignedToId    String?
  category        TicketCategory
  priority        TicketPriority @default(MEDIUM)
  status          TicketStatus   @default(OPEN)
  title           String         @db.VarChar(200)
  description     String
  resolution      String?
  resolvedAt      DateTime?
  closedAt        DateTime?
  dueDate         DateTime?
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tenant     Tenant          @relation(fields: [tenantId], references: [id])
  site       Site            @relation(fields: [siteId], references: [id])
  unit       Unit?           @relation(fields: [unitId], references: [id])
  reportedBy User?           @relation("TicketReportedBy", fields: [reportedById], references: [id])
  assignedTo SiteStaff?      @relation(fields: [assignedToId], references: [id])
  comments   TicketComment[]
  attachments TicketAttachment[]

  @@index([tenantId])
  @@index([tenantId, siteId, status])
  @@index([tenantId, assignedToId, status])
  @@map("tickets")
}

model TicketComment {
  id         String   @id @default(uuid())
  tenantId   String
  ticketId   String
  authorId   String
  body       String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation("TicketCommentAuthor", fields: [authorId], references: [id])

  @@index([tenantId, ticketId])
  @@map("ticket_comments")
}

model TicketAttachment {
  id             String   @id @default(uuid())
  tenantId       String
  ticketId       String
  uploadedById   String
  // storageKey = storage'dan alınan kalıcı referans (ör. s3://bucket/key ya da local path).
  // Publik URL değil; indirme isteğinde FileStorageService ile resolve edilir.
  storageKey     String
  storageDriver  String   @db.VarChar(20)
  mimeType       String   @db.VarChar(100)
  sizeBytes      Int
  originalName   String?  @db.VarChar(255)
  createdAt      DateTime @default(now())

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  ticket     Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation("TicketAttachmentUploadedBy", fields: [uploadedById], references: [id])

  @@index([tenantId, ticketId])
  @@map("ticket_attachments")
}

// ──────────────────────────────────────────
// Hukuki Takip / Icra
// ──────────────────────────────────────────

model LegalCase {
  id              String          @id @default(uuid())
  tenantId        String
  siteId          String
  unitId          String
  residentId      String
  stage           LegalCaseStage  @default(WARNING_SENT)
  status          LegalCaseStatus @default(ACTIVE)
  totalDebt       Decimal         @db.Decimal(12, 2)
  interestRate    Decimal?        @db.Decimal(5, 2)
  collectedAmount Decimal         @db.Decimal(12, 2) @default(0)
  lawyerName      String?
  lawyerPhone     String?
  caseNumber      String?
  courtName       String?
  filedAt         DateTime?
  settledAt       DateTime?
  note            String?
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  site      Site             @relation(fields: [siteId], references: [id])
  unit      Unit             @relation(fields: [unitId], references: [id])
  resident  Resident         @relation(fields: [residentId], references: [id])
  events    LegalCaseEvent[]

  @@index([tenantId])
  @@index([tenantId, siteId, status])
  @@index([tenantId, residentId])
  @@index([status])
  @@map("legal_cases")
}

model LegalCaseEvent {
  id          String         @id @default(uuid())
  tenantId    String
  legalCaseId String
  stage       LegalCaseStage
  description String
  eventDate   DateTime
  createdById String?
  createdAt   DateTime       @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  legalCase LegalCase @relation(fields: [legalCaseId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("LegalCaseEventCreatedBy", fields: [createdById], references: [id])

  @@index([tenantId, legalCaseId])
  @@map("legal_case_events")
}

// ──────────────────────────────────────────
// Belge Yonetimi (Polymorphic)
// ──────────────────────────────────────────

model Document {
  id           String            @id @default(uuid())
  tenantId     String
  ownerType    DocumentOwnerType
  ownerId      String
  type         DocumentType      @default(OTHER)
  fileName     String
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  description  String?
  uploadedById String?
  deletedAt    DateTime?
  createdAt    DateTime          @default(now())

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  uploadedBy User?  @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])

  // Polymorphic: ownerType + ownerId — no DB-level FK, integrity enforced at service layer

  @@index([tenantId])
  @@index([tenantId, ownerType, ownerId])
  @@map("documents")
}

// ──────────────────────────────────────────
// Sozlesme Yonetimi
// ──────────────────────────────────────────

model Contract {
  id           String         @id @default(uuid())
  tenantId     String
  siteId       String
  vendorId     String?
  title        String         @db.VarChar(200)
  description  String?
  status       ContractStatus @default(DRAFT)
  startDate    DateTime
  endDate      DateTime
  amount       Decimal?       @db.Decimal(12, 2)
  currency     String         @default("TRY")
  renewalDate  DateTime?
  autoRenew    Boolean        @default(false)
  createdById  String?
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  site      Site      @relation(fields: [siteId], references: [id])
  vendor    Vendor?   @relation(fields: [vendorId], references: [id])
  createdBy User?     @relation("ContractCreatedBy", fields: [createdById], references: [id])
  expenses  Expense[]

  @@index([tenantId])
  @@index([tenantId, siteId, status])
  @@index([endDate])
  @@map("contracts")
}

// ──────────────────────────────────────────
// Iletisim Kaydi
// ──────────────────────────────────────────

model CommunicationLog {
  id             String               @id @default(uuid())
  tenantId       String
  siteId         String?
  recipientPhone String?
  recipientEmail String?
  residentId     String?
  channel        CommunicationChannel
  status         CommunicationStatus  @default(QUEUED)
  templateKey    String?
  subject        String?
  body           String
  providerMsgId  String?
  sentAt         DateTime?
  deliveredAt    DateTime?
  failedAt       DateTime?
  errorMessage   String?
  metadata       Json?
  sentByUserId   String?
  createdAt      DateTime             @default(now())

  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  site       Site?     @relation(fields: [siteId], references: [id])
  resident   Resident? @relation(fields: [residentId], references: [id])
  sentByUser User?     @relation("CommunicationLogSentBy", fields: [sentByUserId], references: [id])

  @@index([tenantId])
  @@index([tenantId, channel, status])
  @@index([tenantId, residentId])
  @@index([sentAt])
  @@map("communication_logs")
}

// ──────────────────────────────────────────
// Ortak Alan / Tesis
// ──────────────────────────────────────────

model Facility {
  id          String       @id @default(uuid())
  tenantId    String
  siteId      String
  name        String
  type        FacilityType
  description String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  site   Site   @relation(fields: [siteId], references: [id])

  @@unique([tenantId, siteId, name])
  @@index([tenantId, siteId])
  @@map("facilities")
}

// ──────────────────────────────────────────
// Kat Malikleri Toplantisi
// ──────────────────────────────────────────

model Meeting {
  id            String        @id @default(uuid())
  tenantId      String
  siteId        String
  type          MeetingType
  status        MeetingStatus @default(PLANNED)
  title         String        @db.VarChar(200)
  agenda        String?
  date          DateTime
  location      String?
  quorumMet     Boolean?
  attendeeCount Int?
  totalUnits    Int?
  minutesUrl    String?
  createdById   String?
  deletedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  site      Site              @relation(fields: [siteId], references: [id])
  createdBy User?             @relation("MeetingCreatedBy", fields: [createdById], references: [id])
  decisions MeetingDecision[]

  @@index([tenantId])
  @@index([tenantId, siteId, date])
  @@map("meetings")
}

model MeetingDecision {
  id           String         @id @default(uuid())
  tenantId     String
  meetingId    String
  orderNumber  Int
  subject      String
  description  String?
  result       DecisionResult
  votesFor     Int?
  votesAgainst Int?
  votesAbstain Int?
  createdAt    DateTime       @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, orderNumber])
  @@index([tenantId, meetingId])
  @@map("meeting_decisions")
}

// ──────────────────────────────────────────
// Bildirim & Duyuru
// ──────────────────────────────────────────

model Notification {
  id           String              @id @default(uuid())
  tenantId     String
  userId       String?
  residentId   String?
  unitId       String?
  channel      NotificationChannel
  status       NotificationStatus  @default(PENDING)
  templateKey  String?
  title        String?
  body         String?
  payload      Json?
  sentByUserId String?
  sentAt       DateTime?
  failedAt     DateTime?
  errorMessage String?
  readAt       DateTime?
  createdAt    DateTime            @default(now())

  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  user       User?     @relation(fields: [userId], references: [id])
  resident   Resident? @relation(fields: [residentId], references: [id])
  unit       Unit?     @relation(fields: [unitId], references: [id])
  sentByUser User?     @relation("NotificationSentByUser", fields: [sentByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, userId, readAt])
  @@map("notifications")
}

model NotificationPreference {
  id        String              @id @default(uuid())
  tenantId  String
  userId    String
  channel   NotificationChannel
  category  String
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, tenantId, channel, category])
  @@index([tenantId, userId])
  @@map("notification_preferences")
}

model Announcement {
  id          String    @id @default(uuid())
  tenantId    String
  siteId      String?
  title       String    @db.VarChar(200)
  body        String
  publishedAt DateTime?
  createdById String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  site      Site?  @relation(fields: [siteId], references: [id], onDelete: SetNull)
  createdBy User   @relation("AnnouncementCreatedBy", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([siteId])
  @@index([publishedAt])
  @@index([tenantId, publishedAt])
  @@map("announcements")
}

// ──────────────────────────────────────────
// Platform & Sistem
// ──────────────────────────────────────────

model TenantPlan {
  id         String    @id @default(uuid())
  tenantId   String    @unique
  planType   PlanType  @default(TRIAL)
  smsCredits Int       @default(0)
  maxUnits   Int       @default(50)
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("tenant_plans")
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String?
  userId    String
  action    String
  entity    String
  entityId  String
  changes   Json?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model PlatformSetting {
  key         String   @id
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@map("platform_settings")
}

model ExportBatch {
  id                String       @id @default(uuid())
  tenantId          String
  type              ExportType
  status            ExportStatus @default(PENDING)
  filters           Json?
  fileUrl           String?
  requestedByUserId String?
  rowCount          Int?
  createdAt         DateTime     @default(now())
  completedAt       DateTime?

  tenant          Tenant @relation(fields: [tenantId], references: [id])
  requestedByUser User?  @relation("ExportBatchRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, type, status])
  @@map("export_batches")
}

