{
  "name": "@sakin/api-core",
  "version": "0.1.0",
  "private": true,
  "description": "Shared API core primitives for multi-service bootstrap",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "node -e \"console.log('api-core build placeholder (toolchain install required)')\"",
    "dev": "node -e \"console.log('api-core dev placeholder')\"",
