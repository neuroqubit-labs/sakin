# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/sakin_dev?schema=public"

# JWT Auth
JWT_SECRET="dev-jwt-secret-change-me-in-production"
JWT_REFRESH_SECRET="dev-jwt-refresh-secret-change-me"

# App
NODE_ENV="development"
PORT=3001

# iyzico
IYZICO_API_KEY="your-iyzico-api-key"
IYZICO_SECRET_KEY="your-iyzico-secret-key"
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"

# CORS
CORS_ORIGIN="http://localhost:3000"

# File storage: local (varsayılan) | s3 (bağlantı stub — AWS credential eklenince devreye girer)
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./storage"

# SMS provider: mock (varsayılan) | netgsm | iletimerkezi (stub)
SMS_DRIVER="mock"
# OTP yanıtında devCode döndürülsün mü (sadece mock driver aktifken etkilidir)
OTP_RETURN_IN_RESPONSE="true"

# Push provider: mock (varsayılan) | fcm (stub — Firebase credential eklenince devreye girer)
PUSH_DRIVER="mock"
